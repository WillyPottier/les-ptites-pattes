---
const { card } = Astro.props;
---
<div class="tarif-card">
  <div class="tarif-card-head">
    <div class="tarif-icon">{card.emoji}</div>
    <div><h3>{card.label}</h3><span class="sub">{card.sub}</span></div>
  </div>
  <div class="tarif-rows">
    {card.lines.map(([n, p, badge]) =>
      <div class="tarif-row">
        <span class="tarif-row-name">{n}{badge && <span class="tarif-badge">{badge}</span>}</span>
        <span class="tarif-row-price">{p}</span>
      </div>
    )}
  </div>
</div>
